# =============================================================================
# Configuration file for Kind-KEDA Lab Environment
# =============================================================================

# -----------------------------------------------------------------------------
# Binary Versions
# -----------------------------------------------------------------------------

# kind cluster node image version
# Ref: https://github.com/kubernetes-sigs/kind/releases
KIND_NODE_IMAGE="kindest/node:v1.33.1"

# KEDA version (Helm chart)
# Ref: https://github.com/kedacore/charts/releases
KEDA_VERSION="2.19.0"

# RabbitMQ version (Bitnami Helm chart)
# Ref: https://github.com/bitnami/charts/tree/main/bitnami/rabbitmq
RABBITMQ_CHART_VERSION="16.0.14"

# Prometheus stack version (kube-prometheus-stack Helm chart)
# Ref: https://github.com/prometheus-community/helm-charts/tree/main/charts/kube-prometheus-stack
PROMETHEUS_CHART_VERSION="83.4.0"

# Testkube version (Helm chart)
# Ref: https://github.com/kubeshop/helm-charts/releases
TESTKUBE_CHART_VERSION="2.8.3"

# -----------------------------------------------------------------------------
# Cluster Configuration
# -----------------------------------------------------------------------------

# kind cluster name
CLUSTER_NAME="kind-keda-lab"

# kind cluster pod subnet
POD_SUBNET="10.244.0.0/16"

# kind cluster service subnet
SERVICE_SUBNET="10.96.0.0/12"

# kind network name (Docker network)
KIND_NETWORK="kind"

# -----------------------------------------------------------------------------
# Workload Configuration
# -----------------------------------------------------------------------------

# Workload Docker image name
WORKLOAD_IMAGE="kind-keda-lab-workload"
WORKLOAD_IMAGE_TAG="latest"

# Workload namespace
WORKLOAD_NAMESPACE="lab"

# Workload resource defaults
WORKLOAD_CPU_REQUEST="100m"
WORKLOAD_CPU_LIMIT="500m"
WORKLOAD_MEMORY_REQUEST="128Mi"
WORKLOAD_MEMORY_LIMIT="512Mi"

# Workload environment defaults
LOAD_INTENSITY="50"
MEMORY_LIMIT_MB="256"
PROCESSING_DELAY_MS="1000"
METRICS_PORT="8000"
RABBITMQ_URL="amqp://guest:guest@rabbitmq:5672"
RABBITMQ_QUEUE="task-queue"

# -----------------------------------------------------------------------------
# Namespace Configuration
# -----------------------------------------------------------------------------

KEDA_NAMESPACE="keda"
RABBITMQ_NAMESPACE="default"
PROMETHEUS_NAMESPACE="prometheus"
TESTKUBE_NAMESPACE="testkube"

# -----------------------------------------------------------------------------
# Scaling Configuration
# -----------------------------------------------------------------------------

# KEDA polling interval (seconds)
KEDA_POLLING_INTERVAL="15"

# KEDA cooldown period (seconds)
KEDA_COOLDOWN_PERIOD="300"

# Scaling limits
SCALING_MIN_REPLICAS="1"
SCALING_MAX_REPLICAS="10"
